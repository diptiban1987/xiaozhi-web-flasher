  "esp32s3-korvo2-v3": {
    "name": "ESP32-S3 Korvo-2 V3",
    "target": "ESP32-S3",
    "display": "LCD 480x480 (SPI) + Camera",
    "flash": "16MB QIO 80MHz",
    "pins": [
      { "func": "I2S MCLK", "gpio": "GPIO 16", "notes": "Audio master clock" },
